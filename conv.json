    "Document": "description",
    "Help": "help"
  },
  "meta": {
    "matching": "fuzzy",
    "note": "If a user's phrase doesn't exactly match a pattern, AgentD picks the closest matching pattern (bigram/prefix similarity) above a confidence threshold.",
    "placeholders": {
      "{n}": "a number captured from the user's message",
      "{s}": "a free-text string captured from the remainder of the user's message",
      "{n|default}": "a number, falling back to the given default when none was captured"
    }
