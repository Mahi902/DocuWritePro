{
  "version": "1.0",
  "description": "AgentD command registry for SCEditor. Each entry has patterns (user phrases) and an action object that gets postMessaged to the editor.",
  "commands": [
    {
      "id": "set_margin_left",
      "patterns": [
        "set left margin to {n}",
        "set the left margin to {n}",
        "left margin {n}",
        "change left margin to {n}",
        "left margin to {n}",
        "margin left {n}",
        "left margin = {n}"
      ],
      "action": {
        "type": "SET_MARGIN",
        "side": "left",
        "value": "{n}"
      },
      "reply": "Left margin set to {n} cm.",
      "category": "Margins"
